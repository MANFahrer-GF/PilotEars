<Window x:Class="PilotEars.HelpDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PilotEars — Help"
        Width="640" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#14161a" Foreground="#ebebf0"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ebebf0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="LineHeight" Value="20"/>
        </Style>
        <Style x:Key="H1" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ebebf0"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="H2" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#4a9eff"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,18,0,6"/>
        </Style>
        <Style x:Key="H3" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#ebebf0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
        </Style>
        <Style x:Key="Muted" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8b8d97"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="0">
        <Border DockPanel.Dock="Bottom" Background="#1f2229" Padding="20,12" BorderBrush="#2d3138" BorderThickness="0,1,0,0">
            <Button x:Name="CloseBtn" Content="Close" Click="Close_Click"
                    HorizontalAlignment="Right" MinWidth="100" Padding="14,7"
                    Background="#4a9eff" Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" Cursor="Hand"/>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,20,24,20">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
    </DockPanel>
</Window>
