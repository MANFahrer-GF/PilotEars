<Window x:Class="PilotEars.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PilotEars" Width="900" MinHeight="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#14161a"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>

        <!-- ============ COLORS ============ -->
        <SolidColorBrush x:Key="TextPrimary" Color="#ebebf0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#8b8d97"/>
        <SolidColorBrush x:Key="TextTertiary" Color="#5a5d68"/>
        <SolidColorBrush x:Key="CardBg" Color="#1f2229"/>
        <SolidColorBrush x:Key="CardBgHover" Color="#252830"/>
        <SolidColorBrush x:Key="CardBorder" Color="#2d3138"/>
        <SolidColorBrush x:Key="TrackBg" Color="#2d3138"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#4a9eff"/>
        <SolidColorBrush x:Key="AccentBlueDim" Color="#3e8bdf"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#4ade80"/>
        <SolidColorBrush x:Key="AccentOrange" Color="#f59e0b"/>
        <SolidColorBrush x:Key="AccentRed" Color="#f97316"/>
        <SolidColorBrush x:Key="ButtonGhost" Color="#2a2d35"/>

        <!-- ============ LOGO: Pilot Aviation Headset ============ -->
        <DrawingImage x:Key="AppLogo">
            <DrawingImage.Drawing>
                <DrawingGroup>
                    <!-- 1. Background: deep blue → cyan gradient, rounded square -->
                    <GeometryDrawing>
                        <GeometryDrawing.Brush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#60a5fa" Offset="0"/>
                                <GradientStop Color="#2563eb" Offset="0.5"/>
                                <GradientStop Color="#1e3a8a" Offset="1"/>
                            </LinearGradientBrush>
                        </GeometryDrawing.Brush>
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,64,64" RadiusX="14" RadiusY="14"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 2. Glossy top highlight (radial soft white) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Brush>
                            <RadialGradientBrush GradientOrigin="0.3,0.15" Center="0.3,0.15" RadiusX="0.7" RadiusY="0.55">
                                <GradientStop Color="#45ffffff" Offset="0"/>
                                <GradientStop Color="#00ffffff" Offset="1"/>
                            </RadialGradientBrush>
                        </GeometryDrawing.Brush>
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,64,64" RadiusX="14" RadiusY="14"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 3. Inner border highlight (1px lighter ring inside) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#30ffffff" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="1.5,1.5,61,61" RadiusX="13" RadiusY="13"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 4. Headphone band (the curve over the top) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="White" Thickness="3.5" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry>
                                <PathFigure StartPoint="15,30">
                                    <BezierSegment Point1="15,12" Point2="49,12" Point3="49,30"/>
                                </PathFigure>
                            </PathGeometry>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 5. Left ear cup (filled white rounded rect) -->
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="8,28,13,18" RadiusX="4.5" RadiusY="4.5"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 6. Right ear cup -->
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="43,28,13,18" RadiusX="4.5" RadiusY="4.5"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 7. Left speaker grill (3 thin dark lines) -->
                    <GeometryDrawing Brush="#1e3a8a">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="11,32,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                                <RectangleGeometry Rect="11,36,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                                <RectangleGeometry Rect="11,40,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 8. Right speaker grill -->
                    <GeometryDrawing Brush="#1e3a8a">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="46,32,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                                <RectangleGeometry Rect="46,36,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                                <RectangleGeometry Rect="46,40,7,1.2" RadiusX="0.6" RadiusY="0.6"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 9. Microphone boom (curves down-right from left ear cup) -->
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="White" Thickness="2.6" StartLineCap="Round" EndLineCap="Round"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <PathGeometry>
                                <PathFigure StartPoint="14,46">
                                    <BezierSegment Point1="14,53" Point2="17,57" Point3="24,57"/>
                                </PathFigure>
                            </PathGeometry>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 10. Mic capsule (small filled pill at end of boom) -->
                    <GeometryDrawing Brush="White">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="24,54.5,7,5" RadiusX="2.5" RadiusY="2.5"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>

                    <!-- 11. Sound waves emanating right from mic (cyan accent dots) -->
                    <GeometryDrawing Brush="#7dd3fc">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="36,57" RadiusX="1.6" RadiusY="1.6"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#bae6fd">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="42,57" RadiusX="1.3" RadiusY="1.3"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#e0f2fe">
                        <GeometryDrawing.Geometry>
                            <EllipseGeometry Center="48,57" RadiusX="1" RadiusY="1"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingImage.Drawing>
        </DrawingImage>

        <!-- ============ TEXTBLOCK BASE ============ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2,0,4"/>
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas, Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <!-- ============ CARD (replaces GroupBox) ============ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ============ MODERN SLIDER ============ -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Background" Value="{StaticResource TrackBg}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="SmallChange" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="4" CornerRadius="2" Background="{TemplateBinding Background}"/>
                            <Track x:Name="PART_Track" Height="22">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Grid Background="Transparent">
                                                    <Border Height="4" CornerRadius="2"
                                                            Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"
                                                            VerticalAlignment="Center"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="16" Height="16">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Grid>
                                                    <Ellipse Width="16" Height="16"
                                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                                    <Ellipse Width="6" Height="6" Fill="White"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Apply ModernSlider to all Sliders -->
        <Style TargetType="Slider" BasedOn="{StaticResource ModernSlider}"/>

        <!-- ============ BUTTONS ============ -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5fb0ff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentBlueDim}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource ButtonGhost}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="#3a3d45" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#34373f"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22252c"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PresetButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <Style x:Key="PresetButtonActive" TargetType="Button" BasedOn="{StaticResource PresetButton}">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource AccentBlue}" BorderThickness="1"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LangButton" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2d3138"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ CHECKBOX ============ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ============ MODERN DARK COMBOBOX ============ -->
        <Style x:Key="ComboBoxItemDark" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#34373f"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="#2a2d35"/>
            <Setter Property="BorderBrush" Value="#3a3d45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="MaxDropDownHeight" Value="280"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemDark}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="26"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1" Fill="{StaticResource TextSecondary}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M 0,0 L 8,0 L 4,4 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#34373f"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="#4a4d55"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                            <Popup x:Name="Popup" Placement="Bottom" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Slide"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Grid SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      Margin="0,4,0,0">
                                    <Border Background="#252830" BorderBrush="#3a3d45" BorderThickness="1" CornerRadius="6"/>
                                    <ScrollViewer Margin="4">
                                        <VirtualizingStackPanel IsItemsHost="True"
                                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ PROGRESS BAR (meters) ============ -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Background" Value="{StaticResource TrackBg}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="5"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}" CornerRadius="5"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ================== MAIN LAYOUT (two-column body) ================== -->
    <Grid Margin="16,14,16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="Auto"/>  <!-- tagline -->
            <RowDefinition Height="Auto"/>  <!-- presets -->
            <RowDefinition Height="Auto"/>  <!-- two-col body -->
            <RowDefinition Height="Auto"/>  <!-- route info -->
            <RowDefinition Height="Auto"/>  <!-- buttons -->
            <RowDefinition Height="Auto"/>  <!-- footer credit -->
        </Grid.RowDefinitions>

        <!-- ======== Header: Logo + Title + Lang toggle ======== -->
        <Grid Grid.Row="0" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="0" Source="{StaticResource AppLogo}" Width="40" Height="40"
                   VerticalAlignment="Center" Margin="0,0,12,0"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="PilotEars" FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}" Margin="0"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="VersionLabel" Text="v0.2 · VATSIM voice polish"
                               Foreground="{StaticResource TextTertiary}" FontSize="11" Margin="0"
                               VerticalAlignment="Center"/>
                    <Button x:Name="UpdateBanner" Click="UpdateBanner_Click"
                            Visibility="Collapsed" Margin="10,0,0,0" Cursor="Hand"
                            Padding="8,2,8,2" FontSize="10" FontWeight="SemiBold"
                            Background="{StaticResource AccentBlue}" Foreground="White"
                            BorderThickness="0"
                            Content="Update ready — click to restart">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="{TemplateBinding Background}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      TextBlock.Foreground="{TemplateBinding Foreground}"
                                                      TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                                      TextBlock.FontSize="{TemplateBinding FontSize}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="#5b9eff"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="HelpButton" Click="HelpButton_Click" Margin="0,0,6,0"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="{StaticResource TextSecondary}" FontSize="14" FontWeight="Bold"
                        Width="26" Height="26" Padding="0"
                        ToolTip="Help / About">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="13">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  TextBlock.Foreground="{TemplateBinding Foreground}"
                                                  TextBlock.FontWeight="{TemplateBinding FontWeight}"
                                                  TextBlock.FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="b" Property="Background" Value="#2d3138"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="?" Margin="0,-2,0,0"/>
                </Button>
                <ToggleButton x:Name="LangDeButton" Style="{StaticResource LangButton}"
                              Content="DE" Click="LangButton_Click"/>
                <ToggleButton x:Name="LangEnButton" Style="{StaticResource LangButton}"
                              Content="EN" Click="LangButton_Click" IsChecked="True"/>
            </StackPanel>
        </Grid>

        <!-- ======== Tagline ======== -->
        <TextBlock Grid.Row="1" x:Name="TaglineLabel"
                   Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap"
                   Margin="0,4,0,14"
                   Text="Real-time audio polishing for VATSIM radio. Evens out quiet and loud pilots, prevents peaks, and ducks Discord automatically."/>

        <!-- ======== Presets (two rows: builtin + custom) ======== -->
        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <!-- Row 1: built-in presets -->
            <DockPanel>
                <TextBlock x:Name="PresetLabel" Text="Preset:" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"
                           Width="90" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PresetBtnVatsim" Style="{StaticResource PresetButton}" Content="VATSIM" Click="Preset_VATSIM"/>
                    <Button x:Name="PresetBtnLive" Style="{StaticResource PresetButton}" Content="Live" Click="Preset_Live"/>
                    <Button x:Name="PresetBtnAggressive" Style="{StaticResource PresetButton}" Content="Aggressive" Click="Preset_Aggressive"/>
                    <Button x:Name="PresetBtnMinimal" Style="{StaticResource PresetButton}" Content="Minimal" Click="Preset_Minimal"/>
                </StackPanel>
            </DockPanel>

            <!-- Row 2: custom presets (always visible — invites saving) -->
            <DockPanel Margin="0,8,0,0">
                <TextBlock x:Name="CustomPresetLabel" Text="My presets:" Foreground="{StaticResource TextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"
                           Width="90" DockPanel.Dock="Left"/>
                <WrapPanel x:Name="PresetsPanel" Orientation="Horizontal"/>
            </DockPanel>
        </StackPanel>

        <!-- ======== Three-column body ======== -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COL 1: devices + normalizer -->
            <StackPanel Grid.Column="0">

        <!-- ======== Devices ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock x:Name="SectionDevices" Style="{StaticResource SectionTitle}" Text="AUDIO DEVICES"/>
                <TextBlock x:Name="LabelSource" Style="{StaticResource Label}" Text="Source (unused output device vPilot routes to)"/>
                <ComboBox x:Name="InputDeviceBox"
                          DropDownOpened="DeviceBox_DropDownOpened"
                          SelectionChanged="DeviceBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FriendlyName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock x:Name="LabelOutput" Style="{StaticResource Label}" Text="Output (your headset)"/>
                <ComboBox x:Name="OutputDeviceBox"
                          DropDownOpened="DeviceBox_DropDownOpened"
                          SelectionChanged="DeviceBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding FriendlyName}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock x:Name="LabelDiscordSrc" Style="{StaticResource Label}"
                           Text="Discord plays on (optional — used only to duck Discord when radio is active)"/>
                <DockPanel>
                    <Button x:Name="DiscordAutoBtn" DockPanel.Dock="Right" Content="Auto"
                            Click="DiscordAutoBtn_Click" Margin="6,0,0,8"
                            Padding="10,0" FontSize="11" MinWidth="56"
                            Background="#2a2d35" Foreground="{StaticResource TextPrimary}"
                            BorderBrush="#3a3d45" BorderThickness="1" Cursor="Hand"
                            ToolTip="Pick the device currently detected as Discord's output"/>
                    <ComboBox x:Name="DiscordSourceBox"
                              DropDownOpened="DeviceBox_DropDownOpened"
                              SelectionChanged="DiscordSourceBox_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FriendlyName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </DockPanel>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelLatency" Style="{StaticResource Label}" Text="Latency (ms)"/>
                        <Slider x:Name="LatencySlider" Minimum="5" Maximum="200" Value="30"
                                ValueChanged="LatencySlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="LatencyLabel" Style="{StaticResource Value}" Text="30"/>
                </Grid>

                <CheckBox x:Name="AutoStartWithWindowsBox" Margin="0,12,0,0" FontSize="12"
                          Checked="AutoStartWithWindows_Changed" Unchecked="AutoStartWithWindows_Changed">
                    <TextBlock x:Name="LabelAutoStart" Text="Start PilotEars with Windows"/>
                </CheckBox>
                <CheckBox x:Name="AutoEngageOnVPilotBox" Margin="0,4,0,0" FontSize="12"
                          Checked="AutoEngageOnVPilot_Changed" Unchecked="AutoEngageOnVPilot_Changed">
                    <TextBlock x:Name="LabelAutoEngage" Text="Start engine when vPilot/xPilot runs"/>
                </CheckBox>
                <CheckBox x:Name="MinimizeToTrayBox" Margin="0,4,0,0" FontSize="12"
                          Checked="MinimizeToTray_Changed" Unchecked="MinimizeToTray_Changed">
                    <TextBlock x:Name="LabelMinTray" Text="Minimize to system tray"/>
                </CheckBox>
                <CheckBox x:Name="StartMinimizedBox" Margin="0,4,0,0" FontSize="12"
                          Checked="StartMinimized_Changed" Unchecked="StartMinimized_Changed">
                    <TextBlock x:Name="LabelStartMin" Text="Start minimized"/>
                </CheckBox>
            </StackPanel>
        </Border>

        <!-- ======== Normalizer ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock x:Name="SectionNormalizer" Style="{StaticResource SectionTitle}" Text="NORMALIZER (AUTO LEVEL)"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelTarget" Style="{StaticResource Label}" Text="Target loudness (dB)"/>
                        <Slider x:Name="TargetSlider" Minimum="-30" Maximum="-6" Value="-18"
                                ValueChanged="TargetSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="TargetLabel" Style="{StaticResource Value}" Text="-18"/>
                </Grid>
            </StackPanel>
        </Border>

            </StackPanel><!-- /COL 1 -->

            <!-- COL 2: limiter + pan + live levels -->
            <StackPanel Grid.Column="2">

        <!-- ======== Limiter ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock x:Name="SectionLimiter" Style="{StaticResource SectionTitle}" Text="BRICK-WALL LIMITER"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelCeiling" Style="{StaticResource Label}" Text="Ceiling (dB)"/>
                        <Slider x:Name="CeilingSlider" Minimum="-24" Maximum="0" Value="-1"
                                ValueChanged="CeilingSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="CeilingLabel" Style="{StaticResource Value}" Text="-1"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelRelease" Style="{StaticResource Label}" Text="Release (ms)"/>
                        <Slider x:Name="ReleaseSlider" Minimum="5" Maximum="500" Value="50"
                                ValueChanged="ReleaseSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="ReleaseLabel" Style="{StaticResource Value}" Text="50"/>
                </Grid>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelLookahead" Style="{StaticResource Label}" Text="Look-ahead (ms) — 0 = zero added latency"/>
                        <Slider x:Name="LookaheadSlider" Minimum="0" Maximum="200" Value="5" TickFrequency="5"
                                IsSnapToTickEnabled="True" ValueChanged="LookaheadSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="LookaheadLabel" Style="{StaticResource Value}" Text="5"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======== Pan ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock x:Name="SectionPan" Style="{StaticResource SectionTitle}" Text="PAN (L ← CENTER → R)"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <Slider Grid.Column="0" x:Name="PanSlider" Minimum="-1" Maximum="1" Value="0"
                            ValueChanged="PanSlider_ValueChanged"/>
                    <TextBlock Grid.Column="1" x:Name="PanLabel" Style="{StaticResource Value}" Text="C"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ======== Live Meters (signal chain ends here) ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock x:Name="SectionLevels" Style="{StaticResource SectionTitle}" Text="LIVE LEVELS"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="LabelMeterInput" Text="Input" Style="{StaticResource Label}"/>
                    <ProgressBar Grid.Row="0" Grid.Column="1" x:Name="InputMeter" Minimum="0" Maximum="100" Margin="0,5,0,5"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" x:Name="InputMeterLabel" Style="{StaticResource Value}" Text="-∞"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="LabelMeterAgc" Text="AGC gain" Style="{StaticResource Label}"/>
                    <ProgressBar Grid.Row="1" Grid.Column="1" x:Name="AgcMeter" Minimum="0" Maximum="100" Foreground="{StaticResource AccentGreen}" Margin="0,5,0,5"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="AgcMeterLabel" Style="{StaticResource Value}" Text="0"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="LabelMeterOutput" Text="Output" Style="{StaticResource Label}"/>
                    <ProgressBar Grid.Row="2" Grid.Column="1" x:Name="OutputMeter" Minimum="0" Maximum="100" Foreground="{StaticResource AccentOrange}" Margin="0,5,0,5"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="OutputMeterLabel" Style="{StaticResource Value}" Text="-∞"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="LabelMeterDiscord" Text="Discord" Style="{StaticResource Label}"/>
                    <ProgressBar Grid.Row="3" Grid.Column="1" x:Name="DiscordPeakMeter" Minimum="0" Maximum="100" Foreground="#a78bfa" Margin="0,5,0,5"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DiscordPeakLabel" Style="{StaticResource Value}" Text="-∞"/>
                </Grid>
            </StackPanel>
        </Border>

            </StackPanel><!-- /COL 2 -->

            <!-- COL 3: Discord -->
            <StackPanel Grid.Column="4">

        <!-- ======== Discord (more spacious) ======== -->
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SectionDiscord" Style="{StaticResource SectionTitle}" Text="DISCORD AUTO-DUCKING"/>
                    <!-- live indicator: dot turns orange when ducking is active -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Ellipse x:Name="DuckingLed" Width="9" Height="9" Fill="#3a3d45" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DuckingLedLabel" Text="idle" Foreground="{StaticResource TextTertiary}"
                                   FontSize="10.5" VerticalAlignment="Center" Margin="6,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Compact one-line diagnostic: where Discord plays -->
                <Border Background="#16181c" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                    <TextBlock x:Name="DiscordDeviceLabel"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               TextWrapping="Wrap"
                               Text="Discord plays on: —"/>
                </Border>

                <!-- Live ducking visualization: fills orange when Discord is being reduced -->
                <Grid Margin="0,2,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="LabelDuckLive" Text="Discord" Style="{StaticResource Label}"/>
                    <ProgressBar Grid.Column="1" x:Name="DuckLiveMeter" Minimum="0" Maximum="100" Value="0"
                                 Foreground="{StaticResource AccentOrange}" Margin="0,5,0,5"/>
                    <TextBlock Grid.Column="2" x:Name="DuckLiveLabel" Style="{StaticResource Value}" Text="100%"/>
                </Grid>

                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="TestDuckButton" DockPanel.Dock="Right" Click="TestDuckButton_Click"
                            Style="{StaticResource GhostButton}" Content="Test"
                            Padding="14,5" FontSize="11.5" MinWidth="120"/>
                    <CheckBox x:Name="DuckEnabledBox" Content="Enable ducking"
                              IsChecked="True" VerticalAlignment="Center"
                              Checked="DuckEnabled_Changed" Unchecked="DuckEnabled_Changed"/>
                </DockPanel>



                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelDuckAmount" Style="{StaticResource Label}" Text="Duck amount (% reduction)"/>
                        <Slider x:Name="DuckAmountSlider" Minimum="0" Maximum="1" Value="0.5"
                                TickFrequency="0.25" TickPlacement="None"
                                IsSnapToTickEnabled="False"
                                ValueChanged="DuckAmountSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="DuckAmountLabel" Style="{StaticResource Value}" Text="50%"/>
                </Grid>

                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="55"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="LabelDuckThreshold" Style="{StaticResource Label}" Text="Trigger threshold (dB)"/>
                        <Slider x:Name="DuckThresholdSlider" Minimum="-70" Maximum="-5" Value="-34"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="DuckThresholdSlider_ValueChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="1" x:Name="DuckThresholdLabel" Style="{StaticResource Value}" Text="-34"/>
                </Grid>
            </StackPanel>
        </Border>

            </StackPanel><!-- /COL 3 -->
        </Grid><!-- /three-column body -->

        <!-- ======== Route info ======== -->
        <TextBlock Grid.Row="4" x:Name="RouteInfoLabel"
                   Foreground="{StaticResource TextTertiary}" FontSize="11"
                   TextWrapping="Wrap" Margin="0,4,0,12"
                   Text="Pick a non-monitored source device (one not connected to your speakers)."/>

        <!-- ======== Buttons ======== -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BypassButton" Style="{StaticResource GhostButton}" Content="Bypass"
                    Click="BypassButton_Click" MinWidth="100" Margin="0,0,8,0"
                    IsEnabled="False"/>
            <Button x:Name="StartStopButton" Style="{StaticResource PrimaryButton}" Content="Start"
                    Click="StartStopButton_Click" MinWidth="120"/>
        </StackPanel>

        <!-- ======== Footer credit ======== -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,16,0,0">
            <TextBlock x:Name="FooterPre" Text="Made with " Foreground="{StaticResource TextTertiary}" FontSize="11"/>
            <TextBlock Text="♥" Foreground="#ef4444" FontSize="12" Margin="0,-1,0,0"/>
            <TextBlock x:Name="FooterPost" Text=" in Gifhorn  ·  Thomas Kant" Foreground="{StaticResource TextTertiary}" FontSize="11"/>
        </StackPanel>
    </Grid>
</Window>
